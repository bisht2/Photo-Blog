# Dependencies
node_modules/

# Original full-resolution images (kept locally, not deployed)
# Only the optimized versions in _optimized/ go to production
# Excludes all common source formats — Cloudflare Pages has a 25MB per-file limit
images/journeys/*/*.jpg
images/journeys/*/*.jpeg
images/journeys/*/*.JPG
images/journeys/*/*.JPEG
images/journeys/*/*.png
images/journeys/*/*.PNG
images/journeys/*/*.webp
images/journeys/*/*.tiff
images/journeys/*/*.tif
images/journeys/*/*.heic
images/journeys/*/*.HEIC
!images/journeys/_optimized/**

# Video files too large for Cloudflare Pages (25MB limit)
# Host videos on YouTube/Vimeo/Cloudflare Stream instead
images/films/*.MP4
images/films/*.mp4

# Build scripts (local-only tools, not needed on server)
build-images.mjs
update-html-images.mjs

# Build artifacts
*.log
.DS_Store
Thumbs.db

# Editor files
.vscode/
*.swp
*.swo

# npm
package-lock.json

# Stale git directories
.git-old/
.git-ready/
